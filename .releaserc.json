{
  "branches": [
    "main"
  ],
  "tagFormat": "${version}",
  "plugins": [
    "@semantic-release/commit-analyzer",
    [
      "@google/semantic-release-replace-plugin",
      {
        "replacements": [
          {
            "files": [
              "pyproject.toml",
              "packages/hphbiome/pyproject.toml",
              "packages/hphbiome-hiperhealth/pyproject.toml"
            ],
            "from": "version = \".*\"  # semantic-release",
            "to": "version = \"${nextRelease.version}\"  # semantic-release",
            "results": [
              {
                "file": "pyproject.toml",
                "hasChanged": true,
                "numMatches": 1,
                "numReplacements": 1
              },
              {
                "file": "packages/hphbiome/pyproject.toml",
                "hasChanged": true,
                "numMatches": 1,
                "numReplacements": 1
              },
              {
                "file": "packages/hphbiome-hiperhealth/pyproject.toml",
                "hasChanged": true,
                "numMatches": 1,
                "numReplacements": 1
              }
            ],
            "countMatches": true
          },
          {
            "files": [
              "skills-channel.yaml",
              "skills/hphbiome/skill.yaml"
            ],
            "from": "version: .* # semantic-release",
            "to": "version: ${nextRelease.version} # semantic-release",
            "results": [
              {
                "file": "skills-channel.yaml",
                "hasChanged": true,
                "numMatches": 1,
                "numReplacements": 1
              },
              {
                "file": "skills/hphbiome/skill.yaml",
                "hasChanged": true,
                "numMatches": 1,
                "numReplacements": 1
              }
            ],
            "countMatches": true
          }
        ]
      }
    ],
    "@semantic-release/release-notes-generator",
    [
      "@semantic-release/changelog",
      {
        "changelogTitle": "# Release Notes\n---",
        "changelogFile": "CHANGELOG.md"
      }
    ],
    [
      "@semantic-release/exec",
      {
        "prepareCmd": "makim package.build",
        "publishCmd": "twine upload dist/* --username __token__ --password \"$PYPI_TOKEN\""
      }
    ],
    [
      "@semantic-release/github",
      {
        "assets": [
          "dist/*.whl",
          "dist/*.tar.gz"
        ]
      }
    ],
    [
      "@semantic-release/git",
      {
        "assets": [
          "pyproject.toml",
          "packages/hphbiome/pyproject.toml",
          "packages/hphbiome-hiperhealth/pyproject.toml",
          "skills-channel.yaml",
          "skills/hphbiome/skill.yaml",
          "CHANGELOG.md"
        ],
        "message": "chore(release): ${nextRelease.version}"
      }
    ]
  ]
}
